{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/dangerous-actions-blocker.sh" },
          { "type": "command", "command": "bash hooks/bash/prompt-injection-detector.sh" },
          { "type": "command", "command": "bash hooks/bash/permission-request.sh" },
          { "type": "command", "command": "bash hooks/bash/sandbox-validation.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/file-guard-mcp.sh" },
          { "type": "command", "command": "bash hooks/bash/claudemd-scanner.sh" },
          { "type": "command", "command": "bash hooks/bash/privacy-warning.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/output-secrets-scanner.sh" },
          { "type": "command", "command": "bash hooks/bash/security-check.sh" },
          { "type": "command", "command": "bash hooks/bash/repo-integrity-scanner.sh" },
          { "type": "command", "command": "bash hooks/bash/security-gate.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/pre-commit-secrets.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/governance-enforcement-hook.sh" }
        ]
      }
    ]
  }
}
