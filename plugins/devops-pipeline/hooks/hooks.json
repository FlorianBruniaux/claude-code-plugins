{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/pre-commit-evaluator.sh" },
          { "type": "command", "command": "bash hooks/bash/setup-init.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/auto-format.sh" },
          { "type": "command", "command": "bash hooks/bash/typecheck-on-save.sh" },
          { "type": "command", "command": "bash hooks/bash/test-on-change.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/auto-checkpoint.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/notification.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/auto-rename-session.sh" }
        ]
      }
    ]
  }
}
