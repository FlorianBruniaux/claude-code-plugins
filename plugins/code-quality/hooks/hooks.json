{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/validate-changes.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/output-validator.sh" },
          { "type": "command", "command": "bash hooks/bash/governance-enforcement-hook.sh" }
        ]
      }
    ]
  }
}
