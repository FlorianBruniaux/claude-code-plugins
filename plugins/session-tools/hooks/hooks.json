{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/rtk-baseline.sh" }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/identity-reinjection.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/smart-suggest.sh" },
          { "type": "command", "command": "bash hooks/bash/rtk-auto-wrapper.sh" }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/learning-capture.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/subagent-stop.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash hooks/bash/session-summary.sh" },
          { "type": "command", "command": "bash hooks/bash/session-logger.sh" },
          { "type": "command", "command": "bash hooks/bash/auto-rename-session.sh" },
          { "type": "command", "command": "bash hooks/bash/tts-selective.sh" }
        ]
      }
    ]
  }
}
